# ---------------------------------------------------------------
# Google Calendar integration
# ---------------------------------------------------------------
# See BOOKING_SETUP.md for the full walkthrough.

# OAuth 2.0 Web Application client credentials from Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URI used by the one-time setup script (must match the one
# you registered in Google Cloud Console). Leave this as-is unless you
# change the port in scripts/get-google-refresh-token.mjs.
GOOGLE_REDIRECT_URI=http://localhost:3100/callback

# Long-lived refresh token obtained by running the setup script.
# This is the only secret the production server actually needs.
GOOGLE_REFRESH_TOKEN=

# Which of Alison's calendars should receive bookings.
# Use "primary" for her default calendar, or paste a calendar ID
# (looks like an email address) to use a dedicated calendar.
GOOGLE_CALENDAR_ID=primary
